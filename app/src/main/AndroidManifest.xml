<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- Notifikasi & Alarm -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <!-- Camera Feature -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.YeremiWarriors">

        <!-- Splash Screen -->
        <activity
            android:name=".SplashScreenActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Main -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <activity
            android:name=".LoginActivity"
            android:exported="false" />

        <activity
            android:name=".BaseActivity"
            android:exported="false" />

        <!-- Home -->
        <activity
            android:name=".Home.WelcomeActivity"
            android:exported="false" />

        <activity
            android:name=".Home.WebViewActivity"
            android:exported="false" />

        <activity
            android:name=".Home.CustomTwoActivity"
            android:exported="false" />

        <activity
            android:name=".Home.CalculatorActivity"
            android:exported="false" />

        <!-- Pertemuan 3 -->
        <activity
            android:name=".Home.pertemuan_3.ThirdActivity"
            android:exported="false" />

        <activity
            android:name=".Home.pertemuan_3.ThirdResultActivity"
            android:exported="false" />

        <!-- Pertemuan 4 -->
        <activity
            android:name=".Home.pertemuan_4.FourthActivity"
            android:exported="false" />

        <!-- Pertemuan 5 -->
        <activity
            android:name=".Home.pertemuan_5.FifthActivity"
            android:exported="false" />

        <activity
            android:name=".Home.pertemuan_5.WebViewActivity"
            android:exported="false" />

        <!-- Pertemuan 6 -->
        <activity
            android:name=".Home.pertemuan_7.SixthActivity"
            android:exported="false" />

        <!-- Pertemuan 8 -->
        <activity
            android:name=".Home.pertemuan_8.EmailGmailActivity"
            android:exported="false" />

        <activity
            android:name=".Home.pertemuan_8.RegistrationActivity"
            android:exported="false" />

        <activity
            android:name=".Home.pertemuan_8.RegistrationSuccessActivity"
            android:exported="false" />

        <!-- Pertemuan 9 -->
        <activity
            android:name=".Home.pertemuan_9.NinthActivity"
            android:exported="false" />

        <!-- Pertemuan 10 -->
        <activity
            android:name=".Home.pertemuan_10.TenthActivity"
            android:exported="false" />

        <!-- Pertemuan 11 -->
        <activity
            android:name=".Home.pertemuan_11.TutorialMessageActivity"
            android:exported="false" />

        <!-- Pertemuan 13 -->
        <activity
            android:name=".Home.pertemuan_13.ThirteenthActivity"
            android:exported="false" />

        <!-- Note -->
        <activity
            android:name=".Note.NoteFormActivity"
            android:exported="false" />

        <!-- Reminder Receiver -->
        <receiver
            android:name=".utils.ReminderReceiver"
            android:exported="false" />

        <!-- File Provider -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">

            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>