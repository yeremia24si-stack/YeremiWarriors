<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F0FF">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarWelcome"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#3D5AFE"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="@android:color/white" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="32dp"
        android:paddingVertical="48dp">

        <FrameLayout
            android:layout_width="260dp"
            android:layout_height="220dp"
            android:layout_marginBottom="36dp">
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_illustration_card" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎉"
                    android:textSize="72sp" />
            </LinearLayout>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selamat Datang!"
            android:textSize="14sp"
            android:textColor="#3D5AFE"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="di Coinpay"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvWelcomeUsername"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Halo, Pengguna!"
            android:textSize="18sp"
            android:textColor="#3D5AFE"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kami senang kamu bergabung.\nSaatnya kirim, terima, dan pantau\nkeuangan kamu dengan mudah."
            android:textSize="14sp"
            android:textColor="#7B7B9D"
            android:gravity="center"
            android:layout_marginBottom="48dp" />

        <Button
            android:id="@+id/btnContinue"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Lanjutkan"
            android:background="@drawable/bg_button_primary" />
    </LinearLayout>

</LinearLayout>