<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2C4A2E"
    android:padding="32dp">

    <!-- Icon Centang / Sukses -->
    <TextView
        android:id="@+id/tvIconSukses"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✓"
        android:textSize="72sp"
        android:textColor="#A5D6A7"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="180dp" />

    <!-- Judul Berhasil -->
    <TextView
        android:id="@+id/tvHasil"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Kode berhasil dikirim!"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tvIconSukses"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!-- Sub Info -->
    <TextView
        android:id="@+id/tvSubHasil"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Silakan periksa nomor Anda.\nSambut pengalaman wisata desa yang tak terlupakan!"
        android:textSize="15sp"
        android:textColor="#C8E6C9"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvHasil"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Info Nama Desa -->
    <TextView
        android:id="@+id/tvNamaDesa"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🌿 Desa Wisata Nusantara"
        android:textSize="13sp"
        android:textColor="#81C784"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>