<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F0FF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingTop="60dp"
        android:paddingBottom="40dp">

        <!-- LOGO AREA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="36dp">

            <!-- Logo Circle -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center">

                <View
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_logo_circle" />

                <!-- Ganti dengan ImageView jika punya logo sendiri -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="₿"
                    android:textSize="36sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />
            </FrameLayout>

            <!-- App Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="14dp"
                android:text="Coinpay"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:letterSpacing="0.02" />

            <!-- Deskripsi Selamat Datang -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="6dp"
                android:text="Selamat datang! Masuk ke akun Anda\nuntuk mulai bertransaksi."
                android:textSize="13sp"
                android:textColor="#7B7B9D"
                android:gravity="center"
                android:lineSpacingExtra="3dp" />
        </LinearLayout>

        <!-- CARD LOGIN -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#FFFFFF"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Judul Form -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Masuk ke Coinpay"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Masukkan username dan password Anda"
                    android:textSize="12sp"
                    android:textColor="#7B7B9D"
                    android:layout_marginBottom="24dp" />

                <!-- Label Username -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Username"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:layout_marginBottom="8dp" />

                <!-- Input Username -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_input_field"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="14dp"
                    android:layout_marginBottom="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👤"
                        android:textSize="16sp"
                        android:layout_marginEnd="10dp" />

                    <EditText
                        android:id="@+id/etUsername"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="Masukkan username"
                        android:textSize="14sp"
                        android:textColor="#1A1A2E"
                        android:textColorHint="#BBBBD0"
                        android:inputType="text"
                        android:singleLine="true" />
                </LinearLayout>

                <!-- Label Password -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Password"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:layout_marginBottom="8dp" />

                <!-- Input Password -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_input_field"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="14dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔒"
                        android:textSize="16sp"
                        android:layout_marginEnd="10dp" />

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Masukkan password"
                        android:textSize="14sp"
                        android:textColor="#1A1A2E"
                        android:textColorHint="#BBBBD0"
                        android:inputType="textPassword"
                        android:singleLine="true" />

                    <!-- Toggle Password Visibility -->
                    <ImageView
                        android:id="@+id/ivTogglePassword"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@android:drawable/ic_menu_view"
                        android:tint="#BBBBD0"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <!-- Lupa Password -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:text="Lupa password?"
                    android:textSize="12sp"
                    android:textColor="#3D5AFE"
                    android:layout_marginBottom="24dp" />

                <!-- Tombol Login -->
                <Button
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Masuk"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_button_primary"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/btnRegisterGmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="#DB4437"
                    android:text="Register With Gmail"
                    android:textColor="@android:color/white" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Daftar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Belum punya akun? "
                android:textSize="13sp"
                android:textColor="#7B7B9D" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daftar sekarang"
                android:textSize="13sp"
                android:textColor="#3D5AFE"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
