<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F7F2">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarCalculator"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/green_primary"
        app:title="Rumus Bangun Datar"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="@android:color/white" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvHeaderInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Kalkulator Rumus Bangun Datar"
                android:textStyle="italic"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

            <!-- Card Luas Persegi -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Luas Persegi"
                        android:textStyle="bold"
                        android:textColor="@color/green_primary"
                        android:layout_marginBottom="12dp"/>

                    <EditText
                        android:id="@+id/etSisi"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="Masukkan Sisi"
                        android:inputType="numberDecimal"
                        android:background="@drawable/bg_input_field"
                        android:paddingHorizontal="12dp"
                        android:layout_marginBottom="12dp"/>

                    <Button
                        android:id="@+id/btnHitungPersegi"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Hitung Luas"
                        android:backgroundTint="@color/green_primary"/>

                    <TextView
                        android:id="@+id/tvHasilPersegi"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Hasil: -"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:textColor="@color/text_title"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card Luas Persegi Panjang -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Luas Persegi Panjang"
                        android:textStyle="bold"
                        android:textColor="@color/green_primary"
                        android:layout_marginBottom="12dp"/>

                    <EditText
                        android:id="@+id/etPanjang"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="Masukkan Panjang"
                        android:inputType="numberDecimal"
                        android:background="@drawable/bg_input_field"
                        android:paddingHorizontal="12dp"
                        android:layout_marginBottom="8dp"/>

                    <EditText
                        android:id="@+id/etLebar"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="Masukkan Lebar"
                        android:inputType="numberDecimal"
                        android:background="@drawable/bg_input_field"
                        android:paddingHorizontal="12dp"
                        android:layout_marginBottom="12dp"/>

                    <Button
                        android:id="@+id/btnHitungPersegiPanjang"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Hitung Luas"
                        android:backgroundTint="@color/green_primary"/>

                    <TextView
                        android:id="@+id/tvHasilPersegiPanjang"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Hasil: -"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:textColor="@color/text_title"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card Luas Segitiga -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Luas Segitiga"
                        android:textStyle="bold"
                        android:textColor="@color/green_primary"
                        android:layout_marginBottom="12dp"/>

                    <EditText
                        android:id="@+id/etAlas"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="Masukkan Alas"
                        android:inputType="numberDecimal"
                        android:background="@drawable/bg_input_field"
                        android:paddingHorizontal="12dp"
                        android:layout_marginBottom="8dp"/>

                    <EditText
                        android:id="@+id/etTinggi"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="Masukkan Tinggi"
                        android:inputType="numberDecimal"
                        android:background="@drawable/bg_input_field"
                        android:paddingHorizontal="12dp"
                        android:layout_marginBottom="12dp"/>

                    <Button
                        android:id="@+id/btnHitungSegitiga"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Hitung Luas"
                        android:backgroundTint="@color/green_primary"/>

                    <TextView
                        android:id="@+id/tvHasilSegitiga"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Hasil: -"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:textColor="@color/text_title"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>