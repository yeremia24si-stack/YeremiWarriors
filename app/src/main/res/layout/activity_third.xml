<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F0"
    android:padding="24dp">

    <!-- Icon / Gambar Atas -->
    <ImageView
        android:id="@+id/imgdesa"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/bg_illustration_card"
        android:scaleType="centerCrop"
        android:contentDescription="Ilustrasi Desa Wisata"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp" />

    <!-- Judul -->
    <TextView
        android:id="@+id/tvJudul"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Verifikasi Nomor"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#2E7D32"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/imgdesa"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Subjudul -->
    <TextView
        android:id="@+id/tvSubJudul"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Masukkan nomor HP Anda untuk mendaftar sebagai wisatawan Desa Wisata Nusantara"
        android:textSize="14sp"
        android:textColor="#757575"
        android:gravity="center"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvJudul"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Input Nomor HP -->
    <EditText
        android:id="@+id/inputNoTujuan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Contoh: 0812xxxxxxxx"
        android:inputType="phone"
        android:textSize="15sp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp"
        android:background="@drawable/bg_input_field"
        android:layout_marginTop="28dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubJudul"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Tombol Kirim -->
    <Button
        android:id="@+id/btnKirim"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Daftar Sekarang"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#2E7D32"
        android:paddingVertical="14dp"
        android:layout_marginTop="20dp"
        android:elevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/inputNoTujuan"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Info Teks Bawah -->
    <TextView
        android:id="@+id/tvInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="© 2025 Desa Wisata Nusantara"
        android:textSize="12sp"
        android:textColor="#BDBDBD"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>