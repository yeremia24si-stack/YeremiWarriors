<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F8E9"
    android:padding="16dp">

    <!-- ══════════════════════════════════ -->
    <!--   MaterialCardView — Info Desa    -->
    <!-- ══════════════════════════════════ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDesa"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardElevation="6dp"
        android:backgroundTint="#A5D6A7"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- Icon Desa -->
            <TextView
                android:id="@+id/tvIconDesa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌿"
                android:textSize="40sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <!-- Nama Desa (diisi dari Intent) -->
            <TextView
                android:id="@+id/tvNamaDesa"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Desa Wisata Nusantara"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:layout_marginStart="12dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@id/tvIconDesa"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Asal/Lokasi -->
            <TextView
                android:id="@+id/tvAsalDesa"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Lokasi: -"
                android:textSize="14sp"
                android:textColor="#2E7D32"
                android:layout_marginStart="12dp"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/tvNamaDesa"
                app:layout_constraintStart_toEndOf="@id/tvIconDesa"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Tahun Berdiri -->
            <TextView
                android:id="@+id/tvRatingDesa"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Tahun Berdiri: -"
                android:textSize="13sp"
                android:textColor="#388E3C"
                android:layout_marginStart="12dp"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/tvAsalDesa"
                app:layout_constraintStart_toEndOf="@id/tvIconDesa"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ══════════════════════════════════ -->
    <!--   Card Fitur Wisata               -->
    <!-- ══════════════════════════════════ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardFitur"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardElevation="4dp"
        android:backgroundTint="#FFFFFF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardDesa">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvJudulFitur"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="✨ Fitur Unggulan Desa"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tvFiturList"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="🏞️ Pemandangan Alam Indah\n🍃 Wisata Edukasi Pertanian\n🎭 Pertunjukan Budaya Lokal\n🍜 Kuliner Khas Daerah"
                android:textSize="14sp"
                android:textColor="#424242"
                android:lineSpacingExtra="6dp"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/tvJudulFitur"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ══════════════════════════════════ -->
    <!--   Tombol Snackbar                 -->
    <!-- ══════════════════════════════════ -->
    <Button
        android:id="@+id/btnShowSnackbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Info Desa (Snackbar)"
        android:textColor="#FFFFFF"
        android:backgroundTint="#388E3C"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/cardFitur"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══════════════════════════════════ -->
    <!--   Tombol AlertDialog              -->
    <!-- ══════════════════════════════════ -->
    <Button
        android:id="@+id/btnShowAlertDialog"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Daftar Kunjungan (Dialog)"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2E7D32"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnShowSnackbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══════════════════════════════════ -->
    <!--   Tombol Kembali                  -->
    <!-- ══════════════════════════════════ -->
    <Button
        android:id="@+id/btnKembali"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="← Kembali ke Beranda"
        android:textColor="#FFFFFF"
        android:backgroundTint="#757575"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnShowAlertDialog"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>