<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background">

    <LinearLayout
        android:id="@+id/mainLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center">

        <TextView
            android:id="@+id/tvTitleMain"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dashboard Utama"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvDescMain"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Silahkan pilih menu di bawah ini"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/btnRumus"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Rumus Bangun Ruang"
            android:backgroundTint="@color/primary"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnCustom1"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Halaman Welcome (Custom 1)"
            android:backgroundTint="@color/primary"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnCustom2"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Halaman Info (Custom 2)"
            android:backgroundTint="@color/primary"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnWebView"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Bina Desa (WebView)"
            android:backgroundTint="@color/primary"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Logout"
            android:backgroundTint="#E91E63"
            android:layout_marginTop="10dp"/>

    </LinearLayout>
</ScrollView>